# ABC Dashboard – copy to .env and customize (cp .env.example .env)

# --- App
NODE_ENV=production

# --- JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=abc-dashboard
JWT_EMAIL_VERIFICATION_EXPIRES_IN=24h
JWT_PASSWORD_RESET_EXPIRES_IN=10m

# --- Client (frontend origin for CORS/redirects)
CLIENT_URL=http://localhost:3000

# --- Database (PostgreSQL). Docker: host=postgres, port=5432.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=abc_dashboard
POSTGRES_USER=abc_user
# Plain or enc:<hex> (generate: node backend/scripts/encrypt-db-password.js). If enc:, start with ./scripts/docker-compose-up.sh or load-and-run.sh --start-only
POSTGRES_PASSWORD=abc_password

# --- External license API (optional; for sync)
EXTERNAL_LICENSE_API_URL=
EXTERNAL_LICENSE_API_KEY=
# LICENSE_SYNC_SCHEDULE=*/30 * * * *

# --- Cache (Redis). Set REDIS_ENABLED=false for in-memory.
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
CACHE_TYPE=redis
CACHE_USER_DATA_TTL=1800
CACHE_API_RESPONSE_TTL=300

# --- Encryption (64 hex chars; required if using POSTGRES_PASSWORD=enc:)
ENCRYPTION_KEY=
BCRYPT_ROUNDS=14

# --- Email (mailhog | gmail | sendgrid, etc.)
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=ABC Dashboard
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password

# --- Frontend (NEXT_PUBLIC_* inlined at build). Use relative API + proxy for HttpOnly cookies.
NEXT_PUBLIC_USE_RELATIVE_API=true
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
# BACKEND_URL: used by Next.js rewrites to proxy /api/v1. Docker: http://backend:5000; local: http://localhost:5001
NEXT_PUBLIC_APP_ENV=production
WEBSOCKET_ENABLED=false
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=

# --- Next.js Server Actions (base64 32-byte; generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
