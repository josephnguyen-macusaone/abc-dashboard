# Frontend Environment Configuration Example
# Copy this file to create your environment files

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================

# Backend API base URL (env key: NEXT_PUBLIC_API_URL in src/shared/constants/api.ts)
# Inlined at build time; rebuild after changes. Used unless NEXT_PUBLIC_USE_RELATIVE_API=true.
# Docker (make up): backend on host 5001 → use 5001
# Local dev (backend npm run dev): backend on 5000 → use 5000
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Set to 'true' for HttpOnly cookies: requests go to /api/v1 (same origin), Next.js proxies to backend.
# Required for local dev when frontend and backend run on different ports.
NEXT_PUBLIC_USE_RELATIVE_API=true

# WebSocket: In Docker, use WEBSOCKET_ENABLED (root .env). For local dev, set to match backend.
# NEXT_PUBLIC_WEBSOCKET_ENABLED=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application environment
NEXT_PUBLIC_APP_ENV=development

# Role dashboard modules (see src/shared/constants/feature-flags.ts, routes.ts). Omit or 'true' to enable; 'false' to disable.
# When disabled, that role’s /dashboard/<role> URL is blocked and home redirect uses /profile.
# NEXT_PUBLIC_FEATURE_AGENT_MODULE=true
# NEXT_PUBLIC_FEATURE_TECH_MODULE=true
# NEXT_PUBLIC_FEATURE_ACCOUNTANT_MODULE=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Google Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=

# Sentry for error reporting (optional)
NEXT_PUBLIC_SENTRY_DSN=
